{
  "expo": {
    "name": "Same, Bestie",
    "slug": "same-bestie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "same-bestie",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d1c"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.samebestie.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d1c"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.samebestie.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "baseUrl": "/samebestie"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
